#include <stdio.h>


void lerNotas (float notas[], int n);
float calcularMedia (float notas[], int n);
float maiorNota (float notas[], int n);
float menorNota (float notas[], int n);
void exibirResultados (float media, float maior, float menor);


int main() {
    float notas[10];
   
    printf (" EX 1: Estatísticas de Notas\n");
    lerNotas(notas, 10);
   
    float media = calcularMedia (notas, 10);
    float maior = maiorNota (notas, 10);
    float menor = menorNota(notas, 10);
   
    exibirResultados (media, maior, menor);
   
    return 0;
}


void lerNotas(float notas[], int n) {
    for(int i = 0; i < n; i++) {
        printf("Digite a nota %d: ", i + 1);
        scanf("%f", &notas[i]);
    }
}


float calcularMedia (float notas[], int n) {
    float soma = 0;
    for(int i = 0; i < n; i++) {
        soma += notas[i];
    }
    return soma / n;
}


float maiorNota(float notas[], int n) {
    float maior = notas[0];
    for(int i = 1; i < n; i++) {
        if(notas[i] > maior) {
            maior = notas[i];
        }
    }
    return maior;
}


float menorNota(float notas[], int n) {
    float menor = notas[0];
    for(int i = 1; i < n; i++) {
        if(notas[i] < menor) {
            menor = notas[i];
        }
    }
    return menor;
}


void exibirResultados(float media, float maior, float menor) {
    printf("\n RESULTADOS ");
    printf("\nMedia da turma: %.2f", media);
    printf("\nMaior nota: %.2f", maior);
    printf("\nMenor nota: %.2f\n", menor);
}
