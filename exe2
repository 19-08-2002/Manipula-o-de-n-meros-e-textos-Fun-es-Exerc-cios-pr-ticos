#include <stdio.h>

void lerVetor(int v[], int n);
int buscar(int v[], int n, int alvo);
int contar(int v[], int n, int alvo);
void exibirInverso(int v[], int n);

int main() {
    int vetor[15];
    int numeroBusca;
    
    printf("\n EX 2: Busca e Contagem \n");
    lerVetor(vetor, 15);
    
    printf("\nDigite um número para buscar e contar: ");
    scanf("%d", &numeroBusca);
    
    int indice = buscar(vetor, 15, numeroBusca);
    int freq = contar(vetor, 15, numeroBusca);
    
    if(indice != -1) {
        printf("O número %d foi encontrado primeiro no índice: %d\n", numeroBusca, indice);
    } else {
        printf("O número %d não existe no vetor.\n", numeroBusca);
    }
    
    printf("O número %d aparece %d vez(es) no vetor.\n", numeroBusca, freq);
    
    printf("\nVetor em ordem inversa:\n");
    exibirInverso(vetor, 15);
    
    return 0;
}

void lerVetor(int v[], int n) {
    for(int i = 0; i < n; i++) {
        printf("Digite o elemento %d: ", i + 1);
        scanf("%d", &v[i]);
    }
}

int buscar(int v[], int n, int alvo) {
    for(int i = 0; i < n; i++) {
        if(v[i] == alvo) {
            return i;
        }
    }
    return -1;
}

int contar(int v[], int n, int alvo) {
    int freq = 0;
    for(int i = 0; i < n; i++) {
        if(v[i] == alvo) {
            freq++;
        }
    }
    return freq;
}

void exibirInverso(int v[], int n) {
    for(int i = n - 1; i >= 0; i--) {
        printf("%d ", v[i]);
    }
    printf("\n");
}
